# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/threads-collector

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=

# Meta Threads Official API
THREADS_APP_ID=your_app_id
THREADS_APP_SECRET=your_app_secret
THREADS_ACCESS_TOKEN=your_access_token

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Collection Settings
COLLECT_INTERVAL_MINUTES=5
MAX_THREADS_PER_BATCH=100
SCRAPER_CONCURRENCY=3

# Affiliate Tracking
AFFILIATE_TRACKING=true
