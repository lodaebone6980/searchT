{
  "manifest_version": 3,
  "name": "Threads 수집기 - searchT",
  "version": "1.0.0",
  "description": "Meta Threads 피드에서 스레드를 자동/수동 수집하여 searchT 대시보드로 전송합니다.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.threads.net/*",
    "https://www.threads.com/*",
    "https://searcht-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.threads.net/*",
        "https://www.threads.com/*"
      ],
      "js": ["js/utils.js", "js/classifier.js", "js/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
